# Copy this file to .env (which is gitignored) and fill in real values before running
# `docker compose up`. Values left unset here fall back to the defaults baked into
# docker-compose.yml, except NIMBUS_FILE_MANAGER_ADMIN_PASSWORD, which is required.

# --- Database (used by both the db and app services) ---
NIMBUS_FILE_MANAGER_DB_USER=nimbus_file_manager
NIMBUS_FILE_MANAGER_DB_PASSWORD=nimbus_file_manager
NIMBUS_FILE_MANAGER_DB_NAME=nimbus_file_manager

# --- First-login admin account (required - no default on purpose) ---
NIMBUS_FILE_MANAGER_ADMIN_USERNAME=admin@nimbus-file-manager.local
NIMBUS_FILE_MANAGER_ADMIN_PASSWORD=change-me-before-first-boot

# --- Host folder containing the media you want inventoried/organized ---
# Mounted into the container at /library - use /library/... (not this host path) when
# configuring the watch folder or any sourcePath/targetPath from the UI.
NIMBUS_FILE_MANAGER_LIBRARY_PATH=./library

# --- Optional: port the app is reachable on from the host ---
NIMBUS_FILE_MANAGER_PORT=8088

# --- Optional: Google OAuth login (leave disabled unless you configure real credentials) ---
NIMBUS_FILE_MANAGER_GOOGLE_LOGIN_ENABLED=false

# --- Optional: Gmail SMTP for confirmation/reset emails (falls back to logging the link) ---
NIMBUS_FILE_MANAGER_EMAIL_GMAIL_ENABLED=false
NIMBUS_FILE_MANAGER_SMTP_USERNAME=
NIMBUS_FILE_MANAGER_SMTP_PASSWORD=
